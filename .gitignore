# --- Runtime SQLite / DB (배달 사고 방지: 절대 커밋·rsync 소스에 포함 금지) ---
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal

# WAL sidecars (일부 도구가 별도 확장자로 생성)
*-wal
*-shm

# 로컬 팩토리 데이터 루트 전체 (DB_STORAGE_PATH 미러)
factory_data/
dante_data/

