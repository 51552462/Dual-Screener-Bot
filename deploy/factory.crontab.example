# Dual-Screener-Bot — Factory crontab (paste into /etc/cron.d/dual-screener-factory)
# Server path: set FACTORY to your clone directory. chmod +x factory.sh first.
#
# timedatectl may show UTC; CRON_TZ forces schedule interpretation in KST.
#
# US session (NYSE, KST approx.): regular ~23:30–06:00 (DST ±1h). Weekdays 2–6 = Tue–Sat KST
# aligns with Mon–Fri US cash session.

SHELL=/bin/bash
CRON_TZ=Asia/Seoul
PATH=/usr/local/bin:/usr/bin:/bin

FACTORY=/home/ubuntu/Dual-Screener-Bot
FACTORY_USER=ubuntu

# --- KR live sniper (정규장 30분 주기, Mon–Fri KST 09:00–15:30) ---
0,30 9-15 * * 1-5  ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --scan-kr

# --- KR post-close audit (after 15:30 KST settle) ---
# Pipeline: meta_governor_sync → guard → sentiment → spillover → track → deep_dive → report → overseer
35 16 * * 1-5  ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --daily-kr

# --- US live sniper (정규장 대응 30분 주기, Tue–Sat KST ≈ Mon–Fri US) ---
#   DST(서머타임): KST 22:30~05:00 커버
30 22 * * 2-6     ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --scan-us
#   기본 시즌: KST 23:30~06:00 커버 (자정 경계 포함)
0,30 23 * * 2-6   ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --scan-us
0,30 0-6 * * 2-6  ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --scan-us

# --- US post-close audit (US close → KST ~06:00; includes us_data_incremental before report) ---
45 6 * * 2-6   ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --daily-us

# --- Weekly Flow master (Saturday, after optional brain surgery) ---
5 10 * * 6     ${FACTORY_USER}  cd ${FACTORY} && ./factory.sh --weekly

# --- Legacy weekend brain surgery (optional, keep separate from weekly) ---
0 10 * * 6     ${FACTORY_USER}  cd ${FACTORY} && ${FACTORY}/venv/bin/python system_auto_pilot.py --run-autonomous-analysis-only >>${FACTORY}/logs/autonomous_${FACTORY_USER}.log 2>&1

# Manual full daily (not scheduled — use when needed):
#   cd ${FACTORY} && ./factory.sh --daily
