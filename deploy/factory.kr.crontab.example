30 17 * * 1-5  ubuntu  cd /home/ubuntu/dante_bots/Dual-Screener-Bot && TZ=Asia/Seoul bash ./factory.sh --scan-kr-ema5-r2

# --- KR post-close audit (after last scan 17:30) ---
45 18 * * 1-5  ubuntu  cd /home/ubuntu/dante_bots/Dual-Screener-Bot && TZ=Asia/Seoul bash ./factory.sh --daily-kr

# --- US post-close audit (KST morning after NY close) ---
