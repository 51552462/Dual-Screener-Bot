# OOM 보수 기본값 (4GB RAM 권장) — 내용을 서버의 `.env`에 합치거나 systemd EnvironmentFile에 포함
MAX_WORKERS=1
TELEGRAM_CONCURRENCY_LIMIT=4

# 데이터 루트 격리 (선택). 미설정 시 ~/dante_bots/Dual-Screener-Bot
# DB_STORAGE_PATH=/var/lib/quant-factory/data
# 주식(KR/US) 작업 큐 — 코인 bitget_task_queue.sqlite 와 분리
# TASK_QUEUE_DB_PATH=/var/lib/quant-factory/data/task_queue.sqlite
# 레거시 외 위치의 system_config.json만 있을 때 부트스트랩용 (선택)
# SYSTEM_CONFIG_PATH=/var/lib/quant-factory/data/system_config.json

# ── 코인 선행 레이더(canary) — 주식(소비) 측 강제 참조 경로 ──
# 코인 측 bitget_resource_limits.env 의 BITGET_CANARY_STATE_PATH 와 '동일 절대경로'여야 한다.
BITGET_CANARY_STATE_PATH=/home/ubuntu/dante_bots/Dual-Screener-Bot/bitget/bitget_canary_state.json
# 코인 카나리아 → 주식 국면 VIX 페널티 실적용(1=ACTIVE 기본, 0=SHADOW 로그만)
CRYPTO_CANARY_PENALTY_ENABLED=1

# ── [P2-1] 전략 승격 다중검정 보정(Deflated Sharpe) 게이트 (선택) ──
# 0=보고만(기본, 라이브 무영향). >0(예: 0.95)으로 두면 OOS DSR 미달 챔피언은 승격 차단.
# OOS_DSR_MIN=0

# ── [P2-2] 국면별 kelly_cap 자가조정 + floor 도입 (기본 OFF: 하드코딩과 동일) ──
# 1로 켜면 forward_trades 의 국면별 실현 Sharpe 로 kelly_cap 을 0.5~1.5× 클램프 자가조정하고
# floor(=cap×FRAC)를 부여해 위기기 0 락아웃을 방지한다. 핵심 레버이므로 섀도우 관측 후 활성 권장.
# META_KELLY_LEARN_ENABLED=0
# META_KELLY_FLOOR_FRAC=0.2          # floor = 학습 cap × 0.2
# META_KELLY_CAP_MULT_FLOOR=0.5      # cap 배수 하한
# META_KELLY_CAP_MULT_CAP=1.5        # cap 배수 상한
# META_KELLY_LEARN_MIN_TRADES=20     # 국면별 최소 표본(미만이면 미적용)
# META_KELLY_SHARPE_SCALE=0.15       # tanh 민감도(작을수록 가파름)
