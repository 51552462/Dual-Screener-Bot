# OOM 보수 기본값 (4GB RAM 권장) — 내용을 서버의 `.env`에 합치거나 systemd EnvironmentFile에 포함
MAX_WORKERS=1
TELEGRAM_CONCURRENCY_LIMIT=4

# 데이터 루트 격리 (선택). 미설정 시 ~/dante_bots/Dual-Screener-Bot
# DB_STORAGE_PATH=/var/lib/quant-factory/data
# 레거시 외 위치의 system_config.json만 있을 때 부트스트랩용 (선택)
# SYSTEM_CONFIG_PATH=/var/lib/quant-factory/data/system_config.json
