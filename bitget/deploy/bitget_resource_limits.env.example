# Bitget factory resource limits (merge into root .env or bitget/.env)
BITGET_DB_STORAGE_PATH=
BITGET_DASHBOARD_PORT=8511
BITGET_HEATMAP_PORT=8512
BITGET_MAX_WORKERS=8
BITGET_TELEGRAM_CONCURRENCY=3
BITGET_LOG_DIR=
BITGET_WATCHDOG_STALE_SEC=600
BITGET_WATCHDOG_MISS_THRESHOLD=3
BITGET_WATCHDOG_HEARTBEAT_COMPONENT=bitget_auto_pilot

# ── Two-Track air-gap: yield 기본 OFF, 독립 큐·락·cgroup 병렬 가동 ──
BITGET_YIELD_TO_FACTORY=0
# BITGET_TASK_QUEUE_DB_PATH=   # 미설정 시 bitget_data_dir()/bitget_task_queue.sqlite
# 코인(생산)·주식(소비) 두 프로세스가 같은 파일을 가리키도록 root .env 에 동일 값 권장.
BITGET_CANARY_STATE_PATH=/home/ubuntu/dante_bots/Dual-Screener-Bot/bitget/bitget_canary_state.json
