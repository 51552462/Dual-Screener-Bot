# =============================================================================
# Bitget 코인 전용 서버 — 환경 변수 SSOT 예시
#   복사: cp bitget/deploy/bitget.env.example bitget/.env
#   권한: chmod 600 bitget/.env
#   위치: INSTALL_ROOT/bitget/.env  (systemd 가 EnvironmentFile 로 로드)
#
# 주식 서버(Bot-1)에는 이 파일을 두지 말 것. API·텔레그램 키는 코인 전용.
# =============================================================================

# --- 저장소·데이터 루트 (코인 서버 필수) ---
INSTALL_ROOT=/home/ubuntu/dante_bots/Dual-Screener-Bot
BITGET_INSTALL_ROOT=/home/ubuntu/dante_bots/Dual-Screener-Bot
BITGET_DB_STORAGE_PATH=/var/lib/quant-bitget/data
# BITGET_SYSTEM_CONFIG_PATH=/var/lib/quant-bitget/data/bitget_system_config.json

# --- Bitget REST / WebSocket (거래소 API) ---
BITGET_ACCESS_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
# 레거시 별칭 (위 3개와 동일 값 가능):
# BITGET_API_KEY=
# BITGET_API_SECRET=
# BITGET_API_PASSPHRASE=

# --- Telegram (코인 전용 봇·채널 — 주식 TELEGRAM_* 와 분리) ---
BITGET_BOT_TOKEN=
BITGET_BOT_CHAT_ID=
# 선택: 프로모/보조 채널
# BITGET_BOT_PROMO_TOKEN=
# 레거시 별칭:
# BITGET_TELEGRAM_TOKEN=
# BITGET_TELEGRAM_TOKEN_MAIN=
# BITGET_TELEGRAM_CHAT_ID=

# --- systemd 가 기본 설정 (bitget/.env 에 중복해도 무방) ---
BITGET_SKIP_INLINE_TELEGRAM=1
BITGET_ASYNC_TELEGRAM=1
QUANT_SKIP_INLINE_TELEGRAM_DAEMON=1

# --- Two-Track / 2대 분리 서버 (코인 전용 서버에서는 yield 불필요) ---
BITGET_YIELD_TO_FACTORY=0
BITGET_ENQUEUE_ON_YIELD=0

# --- 리소스 (4GB 코인 서버 권장) ---
BITGET_MAX_WORKERS=4
BITGET_TELEGRAM_CONCURRENCY=3
BITGET_LOG_DIR=/home/ubuntu/dante_bots/Dual-Screener-Bot/bitget/logs

# --- 큐·락 (미설정 시 bitget_data_dir() 아래 자동) ---
# BITGET_TASK_QUEUE_DB_PATH=/var/lib/quant-bitget/data/bitget_task_queue.sqlite

# --- CQRS 스냅샷 ---
BITGET_SNAPSHOT_MAX_STALE_SEC=1800
BITGET_REPORT_FORCE_MAIN_DB=1
# BITGET_SNAPSHOT_INTERVAL_SEC=300

# --- 워치독 / 큐 모니터 ---
BITGET_WATCHDOG_HEARTBEAT_COMPONENT=bitget_auto_pilot
BITGET_WATCHDOG_STALE_SEC=600
BITGET_WATCHDOG_MISS_THRESHOLD=3
BITGET_WATCHDOG_ALERT_COOLDOWN_SEC=900
# 값에 공백·sudo -n 이 있으므로 반드시 따옴표 (source .env 시 -n 이 별도 명령으로 실행되는 버그 방지)
BITGET_WATCHDOG_RESTART_CMD="sudo -n /usr/bin/systemctl restart dante-bitget-factory"
BITGET_WATCHDOG_RESTART_QUEUE_CMD="sudo -n /usr/bin/systemctl restart dante-bitget-queue-worker"
BITGET_WATCHDOG_RESTART_WS_CMD="sudo -n /usr/bin/systemctl restart dante-bitget-ws"
BITGET_WATCHDOG_RESTART_ASYNC_CMD="sudo -n /usr/bin/systemctl restart dante-bitget-async"
# Multi-unit matrix (independent miss/cooldown/hourly cap — never cascade / never flatten)
BITGET_WATCHDOG_RESTART_QUEUE=1
BITGET_WATCHDOG_RESTART_WS=1
BITGET_WATCHDOG_RESTART_ASYNC=1
# 0=embedded WS hang → restart factory; 1=dedicated dante-bitget-ws unit
BITGET_WATCHDOG_WS_UNIT=0
# Async HB component (must land in bitget_ops_events via bitget.async_telegram_daemon patch)
# BITGET_WATCHDOG_ASYNC_COMPONENT=async_telegram_daemon
# BITGET_WATCHDOG_ASYNC_STALE_SEC=180
# BITGET_WATCHDOG_ASYNC_PENDING_ALERT=50
BITGET_WATCHDOG_MAX_RESTARTS_PER_HOUR=3
# BITGET_WATCHDOG_WS_BUF_STALE_SEC=300
BITGET_QUEUE_MONITOR_ENABLED=1

# --- 스캔·스케줄 가드 ---
# BITGET_SCAN_MAINTENANCE_UTC_HOURS=2-4,22-23
# BITGET_FACTORY_SCAN_DISABLED=0
# BITGET_FORCE_SCAN=0
# BITGET_LOCK_BREAK_ON_MAX_AGE=1
# BITGET_LOCK_MAX_AGE_SEC=300

# --- UI (RAM 절약 시 dashboard/heatmap systemd disable 가능) ---
BITGET_DASHBOARD_PORT=8511
BITGET_HEATMAP_PORT=8512

# --- 실주문 (가상매매만이면 false 유지) ---
ENABLE_REAL_EXECUTION=false
REAL_EXECUTION_DRY_RUN=true
# Paper ledger + live OMS share GLOBAL_CIRCUIT_BREAKER (system_config JSON SSOT)
# GLOBAL_CIRCUIT_BREAKER=OFF

# --- Portfolio NAV risk gates (system_config; defaults in infra/memory_policy.py) ---
# Reduce new entry size ≥15% MDD → block ≥20% → halt alert ≥30% (never auto-flatten)
# NAV_DD_REDUCE_PCT=15
# NAV_DD_BLOCK_PCT=20
# NAV_DD_HALT_PCT=30
# NAV_DD_REDUCE_SIZE_MULT=0.5
# Hard leverage ceiling for resolve_leverage
# MAX_LEVERAGE=5

# --- OMS orphan escalation (system_config; recon → gate) ---
# Exchange-only positions → OMS_ORPHAN_ACTIVE=ON → block new entries (never auto-flatten)
# OMS_ORPHAN_STREAK_PROPOSE_KILL=2  # consecutive recon → propose Meta KILL_SWITCH (not auto-arm)

# --- Portfolio gross notional cap (open sim_kelly_invest / portfolio NAV; ≤0 disables) ---
# GROSS_NOTIONAL_MAX_PCT=200

# --- BTC-proxy concentration (high-β same-side cluster / NAV; ≤0 disables) ---
# CORR_BTC_MIN=0.60              # pearson vs BTC → high-β
# CORR_CLUSTER_MAX_PCT=100       # same-side high-β open sum / NAV
# CORR_BTC_WINDOW=60
# CORR_BTC_MIN_OVERLAP=20        # soft-pass if fewer bars

# --- Doomsday DEFCON (radar → block new LONG ≤ level; never flatten; SHORT may hedge) ---
# DOOMSDAY_BLOCK_LEVEL=2
# Contagion score written by doomsday_radar as scores.Global_Contagion_Score (Kelly dampen)

# --- Tail-risk reserve (accrual + crisis 1:1 release; underfund size / empty+DD block) ---
# TAIL_RISK_ACCRUAL_PCT=1.5
# TAIL_RISK_MIN_COVERAGE_PCT=0.5   # fund/NAV %; ≤0 disables size shrink
# TAIL_RISK_UNDERFUND_SIZE_MULT=0.5
# TAIL_RISK_CRISIS_ATR_PCT=6.0     # BEAR + BTC_ATR → release fund into treasury 1:1 (never ×N)
# TAIL_RISK_EMPTY_BLOCK=1          # empty fund + MDD≥reduce → block new entries

# --- Config write hard bounds (save/set clamp Kelly, cutoffs, leverage, risk gates) ---
# Bounds SSOT: bitget/infra/config_bounds.py (applied in config_manager save/set/OCC)

# --- Bad-tick / flash-crash price sanity (OHLCV; ≤0 disables a sub-check) ---
# BAD_TICK_LOOKBACK_BARS=5
# BAD_TICK_MAX_GAP_PCT=15
# BAD_TICK_MAX_VS_MEDIAN_PCT=20
# BAD_TICK_MAX_BAR_RANGE_PCT=40
# BAD_TICK_OHLCV_TF=1H

# --- Integrity DB backup + stamped-log GC (cron: bitget.sh --db-backup @00:05 UTC) ---
# BITGET_DB_BACKUP_DIR=/var/lib/quant-bitget/data/backups/db
# Keep newest N tar.gz (default 7); stamped logs TTL days (default 5) in memory_policy

# --- Meta / LLM (선택) ---
# BITGET_META_GOVERNOR_STATE_PATH=/home/ubuntu/dante_bots/Dual-Screener-Bot/bitget_meta_governor_state.json
# BITGET_META_MAX_AGE_HOURS=24
# GEMINI_API_KEY=

# --- Canary (코인 전용 서버 단독 운영 시 주식 소비 없음 — 로컬 경로만) ---
BITGET_CANARY_STATE_PATH=/var/lib/quant-bitget/data/bitget_canary_state.json
# CANARY_EXCLUDE_BASES=

# --- 파이프라인 / 검증 (기본 OFF) ---
# BITGET_PIPELINE_SSOT=0
# BITGET_DAEMON_SNIPER=0
# BITGET_REPORT_HYDRATE_FULL=0
# BITGET_LOAD_TEST_RUN_SCAN=0

# --- Tier-1 WebSocket (factory daemon opt-in; 4GB RAM / channel budget) ---
# Public → StreamBuffer (slippage + order normalize ref price)
BITGET_DAEMON_PUBLIC_WS=0
# Private → OMS positions/orders/account (API keys 필수; pip: websocket-client)
BITGET_DAEMON_PRIVATE_WS=0
# BITGET_WS_EXTRA_SYMBOLS=SOLUSDT,XRPUSDT
# Smoke: plane REST-heavy → hard FAIL (기본은 WARN)
# BITGET_WS_OMS_SMOKE_STRICT=0

# --- ops 로깅 ---
# BITGET_LOG_LEVEL=INFO
# BITGET_DISABLE_OPS_SQLITE_LOG=0

# --- 타임존 (cron UTC SSOT, 로그 KST 참고용) ---
TZ=Asia/Seoul
