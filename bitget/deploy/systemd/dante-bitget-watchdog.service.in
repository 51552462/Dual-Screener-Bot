[Unit]
Description=Bitget heartbeat watchdog (ops_events)
After=network-online.target

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=@@INSTALL_ROOT@@
EnvironmentFile=-@@INSTALL_ROOT@@/.env
EnvironmentFile=-@@INSTALL_ROOT@@/bitget/.env
ExecStart=/bin/bash @@INSTALL_ROOT@@/bitget/deploy/bitget.sh --watchdog

[Install]
WantedBy=multi-user.target
